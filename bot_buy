import pydirectinput
import keyboard
import threading
import time
import sys

try:
    import pygetwindow as gw
    HAS_PYGETWINDOW = True
except ImportError:
    HAS_PYGETWINDOW = False

# --- Configurações ---
TOGGLE_KEY = 'F8'

# --- Estado do bot ---
running = False
bot_thread = None
lock = threading.Lock()


def focus_forza():
    if not HAS_PYGETWINDOW:
        return
    windows = gw.getWindowsWithTitle('Forza Horizon 6')
    if windows:
        try:
            windows[0].activate()
            time.sleep(0.5)
        except Exception:
            pass


def bot_loop():
    global running
    
    while running:
        print("Executando comandos...")
        
        pydirectinput.press('space')
        time.sleep(0.7)
        
        if not running:
            break
        
        pydirectinput.press('s')
        time.sleep(0.7)
        
        if not running:
            break
        
        pydirectinput.press('enter')
        time.sleep(0.7)
        
        if not running:
            break
        
        pydirectinput.press('enter')
        time.sleep(0.7)
        
        if not running:
            break
        
        pydirectinput.press('enter')
        
        print("Comandos executados!")
    
    print("Bot parado.")


def toggle_bot():
    global running, bot_thread
    with lock:
        if not running:
            running = True
            focus_forza()
            bot_thread = threading.Thread(target=bot_loop, daemon=True)
            bot_thread.start()
            print(f"[{TOGGLE_KEY}] Bot ATIVADO.")
        else:
            running = False
            print(f"[{TOGGLE_KEY}] Bot DESATIVADO.")


def main():
    print("Bot Buy pronto.")
    print(f"  {TOGGLE_KEY}  → executar comandos")
    print("  Ctrl+C → encerrar o programa")

    keyboard.add_hotkey(TOGGLE_KEY, toggle_bot)

    try:
        keyboard.wait()
    except KeyboardInterrupt:
        global running
        running = False
        print("\nEncerrando...")
        sys.exit(0)


if __name__ == '__main__':
    main() 